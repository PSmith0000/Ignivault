@page "/"
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject VaultService VaultService
@inject AccountService AccountService
@inject AuthService AuthService

<PageTitle>IgniVault</PageTitle>

<div class="controlregion text-center">
    <h1 class="pageheader">Welcome to IgniVault</h1>
    <p class="pagecontent">
        Securely store and manage your logins, files, and notes in one place.
    </p>
    <ul class="ulstyle">
        <li class="list"><span class="syncfusion-blazor-index-icons e-icons e-lock"></span>Encrypted Login Details</li>
        <li class="list"><span class="syncfusion-blazor-index-icons e-icons e-file"></span>Secure File Storage</li>
        <li class="list"><span class="syncfusion-blazor-index-icons e-icons e-note"></span>Encrypted Notes</li>
    </ul>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            bool tokenValid = await AccountService.IsLoggedInAsync();

            if (tokenValid && user.Identity is not null && user.Identity.IsAuthenticated && !VaultService.IsMasterKeySet())
            {

                // Redirect to dashboard if authenticated
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                // Ensure logout clears any partial session/token
                await AuthService.LogoutAsync();
                Navigation.NavigateTo("/login", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Index] Error during initialization: {ex.Message}");
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
