@page "/"
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject VaultService VaultService
@inject AccountService AccountService
@inject AuthService AuthService
<PageTitle>IgniVault</PageTitle>


@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        bool redirect = false;
        bool tokenValid = await CheckTokenAndMasterKey();
        if (tokenValid && user.Identity is not null && user.Identity.IsAuthenticated)
        {
            redirect = true;
        }

        Console.WriteLine($"AuthState: {tokenValid} {user.Identity != null} {user.Identity.IsAuthenticated}");

        if (redirect)
        {
            Navigation.NavigateTo("/dashboard");
        }
        else
        {
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/login");
        }
    }

    public async Task<bool> CheckTokenAndMasterKey()
    {
        bool masterKeySet = VaultService.IsMasterKeySet();
        bool tokenSet = await AccountService.IsTokenSetAsync();
        Console.WriteLine($"MasterKeySet: {masterKeySet}, TokenSet: {tokenSet}");
        if (masterKeySet && tokenSet)
        {
            return true;
        }

        return false;
    }
}


