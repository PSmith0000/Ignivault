@page "/account"
@attribute [Authorize]
@inject NavigationManager Navigation
@inject AccountService AccountService

<div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="bg-white shadow-lg rounded-2xl p-8 w-full max-w-2xl">
        <h2 class="text-2xl font-semibold text-center text-gray-700 mb-6">My Account</h2>
        <label for="UserID" class="block text-gray-600 mb-2">User ID</label>
        <SfTextBox ID="UserID" @bind-Value="AccountService.LoginUser.Id" Enabled="false"></SfTextBox>

        <label for="Username" class="block text-gray-600 mt-4 mb-2">Username</label>
        <SfTextBox ID="Username" @bind-Value="AccountService.LoginUser.Username"></SfTextBox>

        <label for="Email" class="block text-gray-600 mt-4 mb-2">Email</label>
        <SfTextBox ID="Email" @bind-Value="AccountService.LoginUser.Email"></SfTextBox>
    </div>
</div>

@code {
    

    public void RedirectToLogin()
    {
        Navigation.NavigateTo("/login");
    }

  
    private void UpdateAccount()
    {
        
    }
}
