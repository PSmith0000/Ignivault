@page "/account"
@using QRCoder
@attribute [Authorize]
@inject NavigationManager Navigation
@inject AccountService AccountService
@inject IHttpService HttpService

<div class="min-h-screen flex items-center justify-center bg-gray-100 p-4">
    <div class="bg-white shadow-lg rounded-2xl p-6 w-full max-w-2xl">
        <h2 class="text-2xl font-semibold text-gray-700 text-center mb-6">My Account</h2>

        <!-- Account Details -->
        <div class="mb-6">
            <label class="block text-gray-600 mb-1">User ID</label>
            <SfTextBox @bind-Value="AccountService.LoginUser.Id" Enabled="false" />

            <label class="block text-gray-600 mt-4 mb-1">Username</label>
            <SfTextBox @bind-Value="AccountService.LoginUser.Username" />

            <label class="block text-gray-600 mt-4 mb-1">Email</label>
            <SfTextBox @bind-Value="AccountService.LoginUser.Email" />
        </div>

        <!-- Change Password -->
        <div class="mb-6">
            <h3 class="text-lg font-medium text-gray-700 mb-2">Change Password</h3>
            <SfTextBox @bind-Value="changePasswordModel.CurrentPassword" Placeholder="Current password" Type="InputType.Password" />
            <SfTextBox @bind-Value="changePasswordModel.NewPassword" Placeholder="New password" Type="InputType.Password" class="mt-2" />
            <SfTextBox @bind-Value="confirmNewPassword" Placeholder="Confirm new password" Type="InputType.Password" class="mt-2" />
        </div>

        <!-- Two-Factor Authentication -->
        <div class="mb-6">
            <h3 class="text-lg font-medium text-gray-700 mb-2">Two-Factor Authentication</h3>

            @if (AccountService.LoginUser.TwoFactorEnabled)
            {
                <p class="text-green-600 mb-2">2FA is currently enabled.</p>
                <SfButton CssClass="e-outline e-danger" @onclick="Disable2FA">Disable 2FA</SfButton>
            }
            else
            {
                <p class="text-gray-600 mb-2">2FA is not enabled. Enable it below:</p>
                <SfButton CssClass="e-primary mb-2" @onclick="Show2FAQrCode">Enable 2FA</SfButton>

                @if (showQr)
                {
                    <div class="mt-2 flex flex-col items-center">
                        <SfCard @ref="QRBox">
                            @if (qrCodeValue != null)
                            {
                                <img src="@GetQR()" style="max-width:300px;" />
                            }
                        </SfCard>

                        <SfTextBox @bind-Value="verificationCode" Placeholder="Enter verification code" class="mt-2 w-48" />
                        <SfButton CssClass="e-success mt-2" @onclick="Confirm2FA">Confirm 2FA</SfButton>

                        @if (!string.IsNullOrEmpty(secretKey))
                        {
                            <p class="mt-2 text-sm text-gray-600 text-center">
                                Can't scan? Enter this key manually: <strong>@secretKey</strong>
                            </p>
                        }
                    </div>
                }
            }
        </div>

        <!-- Save Changes -->
        <div class="flex justify-end">
            <SfButton CssClass="e-primary" @onclick="UpdateAccount">Save Changes</SfButton>
        </div>

        <!-- Messages -->
        @if (!string.IsNullOrEmpty(UpdateMessage))
        {
            <SfMessage Severity="@UpdateMessageSeverity" ShowCloseIcon="true" CssClass="mt-4">
                @UpdateMessage
            </SfMessage>
        }
    </div>
</div>

@code {
    private string UpdateMessage = string.Empty;
    private MessageSeverity UpdateMessageSeverity = MessageSeverity.Success;

    ChangePasswordModel changePasswordModel = new();
    private string confirmNewPassword = string.Empty;

    // 2FA
    private string qrCodeValue = string.Empty;
    private bool showQr = false;
    private string verificationCode = string.Empty;
    private string secretKey = string.Empty;
    private SfCard QRBox;
    private byte[] QRBytes;

    private string GetQR()
    {
        return $"data:image/png;base64,{Convert.ToBase64String(QRBytes)}";
    }

    private async Task UpdateAccount()
    {
        if (changePasswordModel.NewPassword != confirmNewPassword)
        {
            UpdateMessage = "New password and confirmation do not match.";
            UpdateMessageSeverity = MessageSeverity.Error;
            return;
        }

        var result = await HttpService.ChangePasswordAsync(changePasswordModel.CurrentPassword, changePasswordModel.NewPassword);

        UpdateMessage = result.Success ? "Account updated successfully!" : result.Message;
        UpdateMessageSeverity = result.Success ? MessageSeverity.Success : MessageSeverity.Error;
    }

    private async Task Show2FAQrCode()
    {
        var result = await HttpService.GetTwoFactorSetupAsync();
        if (result != null)
        {
            qrCodeValue = $"otpauth://totp/Ignivault:{AccountService.LoginUser.Email}?secret={result.SecretKey}&issuer=Ignivault&digits=6";
            secretKey = result.SecretKey;
           

            using (QRCodeGenerator qrGenerator = new QRCodeGenerator())
            using (QRCodeData qrCodeData = qrGenerator.CreateQrCode(qrCodeValue, QRCodeGenerator.ECCLevel.L))
            using (PngByteQRCode qrCode = new PngByteQRCode(qrCodeData))
            {
                byte[] qrCodeImage = qrCode.GetGraphic(20);
                QRBytes = qrCodeImage;
            }

            showQr = true;
        }
        else
        {
            UpdateMessage = "Failed to generate 2FA setup.";
            UpdateMessageSeverity = MessageSeverity.Error;
        }
    }

    private async Task Confirm2FA()
    {
        if (string.IsNullOrWhiteSpace(verificationCode)) return;

        var (success, message, recoveryCodes) = await HttpService.VerifyTwoFactorAsync(verificationCode);
        UpdateMessage = message;
        UpdateMessageSeverity = success ? MessageSeverity.Success : MessageSeverity.Error;

        if (success)
        {
            AccountService.LoginUser.TwoFactorEnabled = true;
            showQr = false;
            verificationCode = string.Empty;

            if (recoveryCodes != null && recoveryCodes.Length > 0)
            {
                UpdateMessage = "2FA Setup Complete.";
                UpdateMessageSeverity = MessageSeverity.Success;
            }
        }
    }

    private async Task Disable2FA()
    {
        UpdateMessage = "2FA disabled";
        UpdateMessageSeverity = MessageSeverity.Success;
        
    }
}
