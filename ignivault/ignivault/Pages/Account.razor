@page "/account"
@attribute [Authorize]
@inject NavigationManager Navigation
@inject AccountService AccountService
@inject IHttpService HttpService

<div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="bg-white shadow-lg rounded-2xl p-8 w-full max-w-2xl">
        <h2 class="text-2xl font-semibold text-center text-gray-700 mb-6">My Account</h2>

        <!-- Account Details -->
        <div class="space-y-4">
            <label for="UserID" class="block text-gray-600">User ID</label>
            <SfTextBox ID="UserID" @bind-Value="AccountService.LoginUser.Id" Enabled="false" Placeholder="User ID" />

            <label for="Username" class="block text-gray-600">Username</label>
            <SfTextBox ID="Username" @bind-Value="AccountService.LoginUser.Username" Placeholder="Enter your username" />

            <label for="Email" class="block text-gray-600">Email</label>
            <SfTextBox ID="Email" @bind-Value="AccountService.LoginUser.Email" Placeholder="Enter your email" />
        </div>

        <!-- Change Password -->
        <div class="mt-6 space-y-4">
            <h3 class="text-lg font-medium text-gray-700 mb-2">Change Password</h3>
            <SfTextBox @bind-Value="changePasswordModel.CurrentPassword" ID="CurrentPassword" Placeholder="Current password" Type="InputType.Password" />
            <SfTextBox @bind-Value="changePasswordModel.NewPassword" ID="NewPassword" Placeholder="New password" Type="InputType.Password" />
            <SfTextBox @bind-Value="confirmNewPassword" ID="ConfirmNewPassword" Placeholder="Confirm new password" Type="InputType.Password" />
        </div>

        <!-- Save Changes Button -->
        <div class="mt-6 flex justify-end">
            <SfButton CssClass="e-primary" @onclick="UpdateAccount">Save Changes</SfButton>
        </div>

        <!-- Optional Messages -->
        @if (!string.IsNullOrEmpty(UpdateMessage))
        {
            <SfMessage Severity="@UpdateMessageSeverity" ShowCloseIcon="true">
                @UpdateMessage
            </SfMessage>
        }
    </div>
</div>

@code {
    private string UpdateMessage = string.Empty;
    private MessageSeverity UpdateMessageSeverity = MessageSeverity.Success;

    ChangePasswordModel changePasswordModel = new();
    private string confirmNewPassword = string.Empty;

    private void RedirectToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task UpdateAccount()
    {
        try
        {
            if(confirmNewPassword != changePasswordModel.NewPassword)
            {
                UpdateMessage = "New password and confirmation do not match.";
                UpdateMessageSeverity = MessageSeverity.Error;
                confirmNewPassword = string.Empty;
                StateHasChanged();
                return;
            }

            var result = await HttpService.ChangePasswordAsync(changePasswordModel.CurrentPassword, changePasswordModel.NewPassword);

            if (result.Success)
            {
                UpdateMessage = "Account updated successfully!";
                UpdateMessageSeverity = MessageSeverity.Success;
            }
            else
            {
                UpdateMessage = result.Message;
                UpdateMessageSeverity = MessageSeverity.Error;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Account update failed: {ex.Message}");
            UpdateMessage = "Failed to update account. Please try again.";
            UpdateMessageSeverity = MessageSeverity.Error;
        }
    }
}
