@page "/signup"
@using ignivault.Core.Interface
@inject NavigationManager NavManager
@inject IHttpService HttpService

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-blue-50 to-blue-100">
    <div class="bg-white shadow-2xl rounded-2xl p-10 w-full max-w-md">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">Ignivault Signup</h2>
        <p class="text-center text-gray-500 mb-8">Sign up to create your account.</p>

        <SfDataForm ID="signup-form" Model="@registration" OnValidSubmit="@HandleValidSubmit">
            <FormValidator>
                <DataAnnotationsValidator />
            </FormValidator>
            <FormItems>
                <FormAutoGenerateItems />
            </FormItems>
            <FormButtons>
                <SfButton type="submit" CssClass="e-primary">Sign-Up</SfButton>
            </FormButtons>
        </SfDataForm>

        @if (showMessage)
        {
            <SfMessage Severity="@messageSeverity" ShowCloseIcon="true">
                @RegistrationStatusMessage
            </SfMessage>
        }
    </div>
</div>

@code {
    private RegistrationModel registration = new RegistrationModel();
    private bool showMessage = false;
    private string RegistrationStatusMessage = string.Empty;
    private MessageSeverity messageSeverity = MessageSeverity.Success;

    private async Task HandleValidSubmit(EditContext context)
    {
        try
        {
            var response = await HttpService.RegisterAsync(registration);

            if (response.Success)
            {
                RegistrationStatusMessage = "Registration successful! Redirecting to login...";
                messageSeverity = MessageSeverity.Success;
                await ShowMessage();

                // Delay slightly before redirect
                await Task.Delay(1000);
                NavManager.NavigateTo("/login?signedup=true");
            }
            else
            {
                RegistrationStatusMessage = $"Registration failed: {response.Message}";
                messageSeverity = MessageSeverity.Error;
                await ShowMessage();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Registration error: {ex.Message}");
            RegistrationStatusMessage = "An unexpected error occurred. Please try again.";
            messageSeverity = MessageSeverity.Error;
            await ShowMessage();
        }
    }

    private async Task ShowMessage()
    {
        showMessage = true;
        StateHasChanged();

        await Task.Delay(10000); // Auto-hide after 10 seconds
        showMessage = false;
        StateHasChanged();
    }
}
