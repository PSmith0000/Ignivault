@page "/login"
@using ignivault.Core.Interface
@inject IJSRuntime JS
@inject VaultService VaultService
@inject NavigationManager NavManager
@inject Blazored.SessionStorage.ISessionStorageService LocalStorage
@inject AuthService AuthService
@inject IHttpService HttpService
@inject AccountService AccountService

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-blue-50 to-blue-100">
    <div class="bg-white shadow-2xl rounded-2xl p-10 w-full max-w-md">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">Ignivault Login</h2>
        <p class="text-center text-gray-500 mb-8">Please login to continue</p>

        <!-- Login Form -->
        <SfDataForm ID="login-form" Model="@loginData">
            <FormValidator>
                <DataAnnotationsValidator />
            </FormValidator>
            <FormItems>
                <FormItem Field="@nameof(LoginUserModel.Email)" LabelText="Email" EditorType="FormEditorType.TextBox" />
                <FormItem Field="@nameof(LoginUserModel.Password)" LabelText="Password" EditorType="FormEditorType.Password" />
            </FormItems>
            <div class="flex justify-between mt-4">
                <FormButtons>
                    <SfButton OnClick="HandleValidSubmit" CssClass="e-primary w-full mr-2">Sign In</SfButton>
                    <SfButton CssClass="e-secondary w-full ml-2" OnClick="@ToggleForgotPasswordDialog">Reset</SfButton>
                </FormButtons>
            </div>
        </SfDataForm>

        <p class="text-center text-gray-600 text-sm mt-6">
            <a href="/signup" class="text-blue-600 hover:underline">Don’t have an account?</a>
        </p>

        @if (ForgotPasswordDialogVisible)
        {
            <ForgotLoginDialog />
        }

        @if (showSuccess)
        {
            <SfMessage Severity="MessageSeverity.Success" ShowCloseIcon="true">
                Registration Successful! Please login.
            </SfMessage>
        }
        else if (loginFailed)
        {
            <SfMessage Severity="MessageSeverity.Error" ShowCloseIcon="true">
                Login failed. Please check your credentials and try again.
            </SfMessage>
        }

        <AskKey @ref="keyDialog"/>

    </div>
</div>

@code {
    private LoginUserModel loginData = new LoginUserModel();
    private AskKey keyDialog;
    private bool ForgotPasswordDialogVisible { get; set; } = false;
    private bool loginFailed = false;
    private bool showSuccess = false;
    private bool DecryptionSuccess = false;



    protected override void OnInitialized()
    {
        // Optional default credentials for dev/testing
        loginData.Email = "user@user.com";
        loginData.Password = "1Password!";

        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        showSuccess = query["signedup"] == "true";
    }

    private void ToggleForgotPasswordDialog() => ForgotPasswordDialogVisible = !ForgotPasswordDialogVisible;

    private async Task PromptAndDecryptAsync(LoginUser user)
    {
        var key = await keyDialog!.ShowAndWaitAsync();
        if (!string.IsNullOrEmpty(key))
        {
            bool status = await VaultService.DecryptMasterKeyAsync(user, key);
            DecryptionSuccess = status;
        }
    }

    private async Task HandleValidSubmit()
    {
        loginFailed = false;

        try
        {
            // Attempt login
            var user = await HttpService.LoginAsync(loginData.Email, loginData.Password);
            if (user == null)
            {
                loginFailed = true;
                return;
            }

            // Verify token expiration
            if (DataUtils.IsTokenExpired(user.Token))
            {
                loginFailed = true;
                return;
            }

            // Decrypt master key
            await PromptAndDecryptAsync(user);
            if (!DecryptionSuccess)
            {
                loginFailed = true;
                return;
            }
     
            // Set user account and store token
            AccountService.SetAccount(user);
            await AuthService.LoginAsync(user.Token);

            // Navigate to dashboard
            NavManager.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Login failed: {ex.Message}");
            loginFailed = true;
        }
    }

}

