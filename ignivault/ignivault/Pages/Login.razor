@page "/login"
@using ignivault.Core.Interface
@inject IJSRuntime JS
@inject VaultService VaultService
@inject NavigationManager NavManager
@inject Blazored.SessionStorage.ISessionStorageService LocalStorage
@inject AuthService AuthService
@inject IHttpService HttpService
@inject AccountService AccountService

<div class="relative flex items-center justify-center min-h-screen bg-gradient-to-br from-blue-50 to-blue-100">
    <div class="bg-white shadow-2xl rounded-2xl p-10 w-full max-w-md">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">Ignivault Login</h2>
        <p class="text-center text-gray-500 mb-8">Please login to continue</p>

        <!-- Login Form -->
        <SfDataForm ID="login-form" Model="@loginData">
            <FormValidator>
                <DataAnnotationsValidator />
            </FormValidator>
            <FormItems>
                <FormItem Field="@nameof(LoginUserModel.Email)" LabelText="Email" EditorType="FormEditorType.TextBox" />
                <FormItem Field="@nameof(LoginUserModel.Password)" LabelText="Password" EditorType="FormEditorType.Password" />
            </FormItems>
            <div class="flex justify-between mt-4">
                <FormButtons>
                    <SfButton OnClick="HandleValidSubmit" CssClass="e-primary w-full mr-2">Sign In</SfButton>
                    <SfButton CssClass="e-secondary w-full ml-2" OnClick="@ToggleForgotPasswordDialog">Reset</SfButton>
                </FormButtons>
            </div>
        </SfDataForm>

        <p class="text-center text-gray-600 text-sm mt-6">
            <a href="/signup" class="text-blue-600 hover:underline">Don’t have an account?</a>
        </p>

        @if (ForgotPasswordDialogVisible)
        {
            <ForgotLoginDialog />
        }

        @if (showSuccessMessage)
        {
            <SfMessage Severity="MessageSeverity.Success" ShowCloseIcon="true">
                @successMessage
            </SfMessage>
        }

        @if (showErrorMessage)
        {
            <SfMessage Severity="MessageSeverity.Error" ShowCloseIcon="true">
                @errorMessage
            </SfMessage>
        }

        <AskKey @ref="keyDialog" />

        @if (showProgressThing)
        {
            <div class="absolute inset-0 bg-gray-200 bg-opacity-50 flex justify-center items-center z-50">
                <SfSpinner Size="40" Label="Processing..." Type="SpinnerType.Tailwind" Visible="true"></SfSpinner>
            </div>
        }
    </div>
</div>

@code {
    private LoginUserModel loginData = new LoginUserModel();
    private AskKey keyDialog;
    private bool ForgotPasswordDialogVisible { get; set; } = false;
    private bool showProgressThing = false;
    private bool DecryptionSuccess = false;

    private bool showSuccessMessage = false;
    private string successMessage = string.Empty;

    private bool showErrorMessage = false;
    private string errorMessage = string.Empty;

    private bool vaultReset = false;

    protected override void OnInitialized()
    {
        loginData.Email = "user@user.com";
        loginData.Password = "1Password!";

        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["signedup"] == "true")
        {
            showSuccessMessage = true;
            successMessage = "Registration Successful! Please login.";
        }
    }

    private void ToggleForgotPasswordDialog() => ForgotPasswordDialogVisible = !ForgotPasswordDialogVisible;

    private async Task PromptAndDecryptAsync(LoginUser user)
    {
        var keyResult = await keyDialog!.ShowAndWaitAsync();
        if (!keyResult.HasValue) return;

        if (!keyResult.Value.reset)
        {
            if (!string.IsNullOrEmpty(keyResult.Value.DecryptionKey))
            {
                showProgressThing = true;
                StateHasChanged();

                DecryptionSuccess = await VaultService.DecryptMasterKeyAsync(user, keyResult.Value.DecryptionKey);

                showProgressThing = false;
                StateHasChanged();

                if (!DecryptionSuccess)
                {
                    ShowError("Vault decryption failed. Please check your key.");
                }
            }
        }
        else
        {
            showProgressThing = true;
            StateHasChanged();

            try
            {
                var resetResult = await HttpService.ResetVaultKeyAsync(keyResult.Value.DecryptionKey, keyResult.Value.NewKey, user.Token);
                Console.WriteLine("RESET");
                showProgressThing = false;
                StateHasChanged();

                if (resetResult.Success)
                {
                    DecryptionSuccess = true;
                    vaultReset = true;
                    ShowSuccess("Vault reset successfully. You may now continue.");
                }
                else
                {
                    DecryptionSuccess = false;
                    ShowError(resetResult.Message);
                }
            }
            catch (Exception ex)
            {
                showProgressThing = false;
                DecryptionSuccess = false;
                ShowError($"Vault reset error: {ex.Message}");
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        ClearMessages();

        try
        {
            var user = await HttpService.LoginAsync(loginData.Email, loginData.Password);
            if (user == null || DataUtils.IsTokenExpired(user.Token))
            {
                ShowError("Login failed. Please check your credentials.");
                return;
            }

            await PromptAndDecryptAsync(user);

            if (!DecryptionSuccess) return;

            AccountService.SetAccount(user);
            await AuthService.LoginAsync(user.Token);

            if (vaultReset)
            {
                NavManager.NavigateTo("/dashboard", true);
            }
            else
            {
                NavManager.NavigateTo("/dashboard");
            }
        }
        catch (Exception ex)
        {
            ShowError($"Login failed: {ex.Message}");
        }
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        showErrorMessage = true;
        showSuccessMessage = false;
    }

    private void ShowSuccess(string message)
    {
        successMessage = message;
        showSuccessMessage = true;
        showErrorMessage = false;
    }

    private void ClearMessages()
    {
        showErrorMessage = false;
        showSuccessMessage = false;
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
