@page "/login"
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Calendars
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using ignivault.Data.Models.Auth
@inject HttpClient Http
@inject IJSRuntime JS

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-blue-50 to-blue-100">
    <div class="bg-white shadow-2xl rounded-2xl p-10 w-full max-w-md">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">Ignivault Login</h2>
        <p class="text-center text-gray-500 mb-8">Please login to continue</p>

        <!-- Login Form -->
        <SfDataForm ID="forgot-form" Model="@login_data" OnValidSubmit="@HandleValidSubmit">
            <FormValidator>
                <DataAnnotationsValidator></DataAnnotationsValidator>
            </FormValidator>
            <FormItems>
                <FormAutoGenerateItems></FormAutoGenerateItems>
            </FormItems>
            <FormButtons>
                <SfButton type="submit" CssClass="e-primary">
                    Sign In
                </SfButton>
                <SfButton type="button" CssClass="e-secondary" OnClick="@ToggleForgotPasswordDialog">
                    Reset
                </SfButton>
            </FormButtons>
        </SfDataForm>

        @if (ForgotPasswordDialogVisible)
        {
            <ForgotLoginDialog />
        }

        <!-- Sign Up -->
        <p class="text-center text-gray-600 text-sm mt-6">
            <a href="">Don’t have an account?</a>
        </p>
    </div>
</div>

@code {
    private LoginUserModel login_data = new();
    private bool ForgotPasswordDialogVisible { get; set; } = false;
    private bool loginFailed = false;

    private void ToggleForgotPasswordDialog()
    {
        ForgotPasswordDialogVisible = !ForgotPasswordDialogVisible;
    }


    private async void HandleValidSubmit(EditContext context)
    {
        try
        {
            loginFailed = false;

            var response = await Http.PostAsJsonAsync("https://localhost:7158/api/Authentication/login", login_data);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginTokenResponse>();
                var token = result.Token;
                await JS.InvokeVoidAsync("localStorage.setItem", "authToken", token);

                //UI
                Console.WriteLine("Login successful: " + token);
            }
            else
            {
                loginFailed = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
}
