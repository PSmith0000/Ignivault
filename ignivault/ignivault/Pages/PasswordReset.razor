@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Nav
@inject IHttpService HttpService

<h3>Reset Your Password</h3>

@if (!string.IsNullOrEmpty(_status))
{
    <div class="alert @( _isSuccess ? "alert-success" : "alert-danger")">@_status</div>
}

@if (!_isTokenValid)
{
    <div class="alert alert-danger">Invalid or missing reset link.</div>
}
else
{
    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Hidden token -->
    <input type="hidden" @bind="_model.Token" />

    <div class="mb-3">
        <label class="form-label fw-bold">New Password</label>
        <InputText @bind-Value="_model.NewPassword"
                   type="password"
                   class="form-control" />
        <ValidationMessage For="@(() => _model.NewPassword)" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Confirm Password</label>
        <InputText @bind-Value="ConfirmPassword"
                   type="password"
                   class="form-control" />
        <ValidationMessage For="@(() => ConfirmPassword)" />
    </div>

    <button class="btn btn-primary" disabled="@_isSubmitting">
        @(_isSubmitting ? "Submitting..." : "Reset Password")
    </button>
</EditForm>
}

@code {
    private ResetPasswordModel _model = new();
    private bool _isSubmitting;
    private string? _status;
    private bool _isSuccess;
    private bool _isTokenValid;
    private string ConfirmPassword = string.Empty;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        string token = query["token"] ?? string.Empty;
        string email = query["email"] ?? string.Empty;

        if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(email))
        {
            _isTokenValid = false;
            _status = "Invalid reset link.";
        }
        else
        {
            _isTokenValid = true;
            _model.Token = token;
            _model.Email = email;
        }
    }

    private async Task HandleSubmit()
    {
        if (_model.NewPassword != ConfirmPassword)
        {
            _status = "Passwords do not match.";
            _isSuccess = false;
            return;
        }

        try
        {
            _isSubmitting = true;

            var (success, message) = await HttpService.ResetPasswordAsync(_model);

            _status = message ?? (success ? "Password has been reset. You can now log in." : "Reset failed.");
            _isSuccess = success;

            if (success)
            {
                await Task.Delay(2000);
                Nav.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            _status = $"Error: {ex.Message}";
            _isSuccess = false;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
