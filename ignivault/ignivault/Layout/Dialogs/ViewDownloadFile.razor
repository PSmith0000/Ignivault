@using ignivault.Data.Models.Data
@inject IHttpService HttpService
@inject Blazored.SessionStorage.ISessionStorageService LocalStorageService;
@inject IJSRuntime JS
@implements IModalDialog<VaultItem>

<SfDialog @bind-Visible="_showDialog"
          AllowDragging="true"
          @ref="_dialog"
          Width="400px"
          ShowCloseIcon="true"
          CssClass="custom-dialog"
          IsModal="true"
          Header="Download File">
    <DialogTemplates>
        <Content>
            @if (_fileItem != null)
            {
                <div class="mb-4">
                    <p><strong>File Name:</strong> @_fileItem.Name</p>
                    <p><strong>Type:</strong> @_fileItem.Type</p>
                </div>
                <SfButton IsPrimary="true" OnClick="DownloadFile">Download</SfButton>
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <p class="text-red-600 mt-2">@_errorMessage</p>
                }
            }
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private bool _showDialog;
    private VaultItem _fileItem;
    private SfDialog _dialog;
    private string _errorMessage;

    [Parameter] public EventCallback<ToastModel> OnFileDownloaded { get; set; }

    /// <summary>
    /// Load the VaultItem for download.
    /// </summary>
    public async Task SetVaultItem(VaultItem item)
    {
        _fileItem = item;
        _showDialog = true;
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (_fileItem == null)
            return;

        try
        {
            var token = await LocalStorageService.GetItemAsync<string>("authToken");
            if (string.IsNullOrEmpty(token))
            {
                _errorMessage = "User is not authenticated.";
                return;
            }

            var url = $"{HttpService.ApiBaseUrl}api/vault/download-file?id={_fileItem.Id}";

            await HideAsync();

            ToastModel toastModel = new ToastModel()
            {
                Title = "File Download",
                Content = $"Starting Download: {_fileItem.Name}",
                CssClass = "e-toast-info",
                ShowProgressBar = true,
                ShowCloseButton = true,
                Timeout = 3000
            };
            await OnFileDownloaded.InvokeAsync(toastModel);

            // Download via JS with JWT
            await JS.InvokeVoidAsync("Downloadhelper.downloadWithJwt", url, token, $"{_fileItem.Name}-{_fileItem.Id}");

            if (OnFileDownloaded.HasDelegate)
            {
                toastModel.Content = $"{_fileItem.Name} Complete.";
                toastModel.CssClass = "e-toast-success";
                await OnFileDownloaded.InvokeAsync(toastModel);
            }
        }
        catch (Exception ex)
        {
            await OnFileDownloaded.InvokeAsync(new ToastModel()
            {
                Title = "File Download",
                Content = $"Failed Download: {_fileItem.Name}",
                CssClass = "e-toast-danger",
                ShowProgressBar = true,
                ShowCloseButton = true,
                Timeout = 3000
            });
            _errorMessage = $"Download failed: {ex.Message}";
        }
    }

    public async Task ShowAsync() => await _dialog.ShowAsync();
    public async Task HideAsync()
    {
        _showDialog = false;
        await _dialog.HideAsync();
    }
}
