<SfDialog @bind-Visible="IsOpen"
          Width="400px"
          Header="Two-Factor Authentication"
          IsModal="true"
          ShowCloseIcon="false"
          CssClass="otp-dialog">
    <DialogTemplates>
        <Content>
            <div class="flex flex-col items-center p-4 space-y-4">
                <p class="text-gray-700 text-center">
                    Enter the 6-digit code from your authenticator app
                </p>

                <SfOtpInput @bind-Value="OTP"
                            Length="6"
                            Type="OtpInputType.Number"
                            Placeholder="-"
                            IsPassword="false"
                            InputStyle="width: 40px; height: 50px; margin: 0 4px; font-size: 1.5rem; text-align: center; border-radius: 8px; border: 1px solid #ccc;" />

                @if (ShowWarning)
                {
                    <p class="text-red-600 text-sm text-center">
                        Please enter the 6-digit code.
                    </p>
                }

                <div class="flex justify-between w-full mt-2">
                    <SfButton CssClass="e-secondary w-1/2 mr-2" @onclick="Cancel">Cancel</SfButton>
                    <SfButton CssClass="e-primary w-1/2 ml-2" @onclick="Submit">Verify</SfButton>
                </div>
            </div>
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private bool IsOpen { get; set; } = false;
    private string OTP { get; set; } = string.Empty;
    private bool ShowWarning { get; set; } = false;

    private TaskCompletionSource<string?>? _tcs;

    public Task<string?> ShowAndWaitAsync()
    {
        OTP = string.Empty;
        ShowWarning = false;
        IsOpen = true;

        _tcs = new TaskCompletionSource<string?>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(OTP) || OTP.Length != 6)
        {
            ShowWarning = true;
            StateHasChanged();
            return;
        }

        _tcs?.TrySetResult(OTP);
        Close();
    }

    private void Cancel()
    {
        _tcs?.TrySetResult(null);
        Close();
    }

    private void Close()
    {
        IsOpen = false;
        OTP = string.Empty;
        ShowWarning = false;
        StateHasChanged();
    }
}
