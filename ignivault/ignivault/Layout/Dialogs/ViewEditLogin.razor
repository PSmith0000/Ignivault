@using System.Collections.ObjectModel
@using ignivault.Data.Models.Data

@inject VaultService VaultService
@inject AccountService AccountService

@if (_loginDetail != null)
{
    <SfDialog @bind-Visible="@_ShowDialog" AllowDragging="true" @ref="_dialog" Width="400px" ShowCloseIcon="true" AllowPrerender=true>
        <DialogTemplates>
            <Content>
                <label class="text-lg font-bold mb-4">Login Details</label>
                <SfDataForm ID="ViewEditLoginItemForm" Model="_loginDetail" ColumnSpacing="20px">
                    <FormValidator>
                        <DataAnnotationsValidator></DataAnnotationsValidator>
                    </FormValidator>
                    <FormItems>
                        <FormAutoGenerateItems></FormAutoGenerateItems>
                    </FormItems>
                    <FormButtons>
                        <SfButton CssClass="e-outline" OnClick="Cancel">Cancel</SfButton>
                        <SfButton IsPrimary="true" OnClick="SaveItem">Save Entry</SfButton>
                    </FormButtons>
                </SfDataForm>
            </Content>
        </DialogTemplates>
    </SfDialog>
}

@code {
    private bool _ShowDialog { get; set; } = false;

    private VaultItem _VaultItem { get; set; }

    [Parameter]
    public EventCallback<RecordTypes.ItemUpdate> OnItemUpdated { get; set; }

    private RecordTypes.LoginDetail? _loginDetail;

    private SfDialog _dialog;

    public async Task SetVaultItem(VaultItem item)
    {
        _VaultItem = item;
        if(_VaultItem != null)
        {
            _loginDetail = await VaultService.DecryptRecordType<RecordTypes.LoginDetail>(_VaultItem);
            StateHasChanged();
        }
        _ShowDialog = true;
    }

    private async Task ItemUpdated(RecordTypes.ItemUpdate update)
    {
        if (update != null)
        {
            await OnItemUpdated.InvokeAsync(update);
        }
    }

    public async Task ShowAsync()
    {
        await _dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        _ShowDialog = false;
        await _dialog.HideAsync();
    }

    private async Task SaveItem()
    {
        string json = System.Text.Json.JsonSerializer.Serialize(_loginDetail);
        string json64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
        var json_encrypted = await VaultService.EncryptBase64(json64, VaultService.GetMasterKeyBase64());

        if(_VaultItem.EncryptedData != json_encrypted.Ciphertext)
        {
            _VaultItem.EncryptedData = json_encrypted.Ciphertext;
            _VaultItem.IV = json_encrypted.IV;
            _VaultItem.Name = _loginDetail.Name;
            await ItemUpdated(new RecordTypes.ItemUpdate(_VaultItem, true));
        }

        await HideAsync();
    }

    private async Task Cancel()
    {
        await HideAsync();
    }
}