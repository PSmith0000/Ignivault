@using ignivault.Data.Models.Data
@implements IModalDialog<VaultItem>
@inject VaultService VaultService

<SfDialog @bind-Visible="_showDialog"
          AllowDragging="true"
          @ref="_dialog"
          Width="400px"
          ShowCloseIcon="true"
          IsModal="true"
          Header="Edit Login">
    <DialogTemplates>
        <Content>
            <SfDataForm Model="vItem" ID="ViewEditLoginForm" ColumnSpacing="20px">
                <FormValidator><DataAnnotationsValidator /></FormValidator>
                <FormItems>
                    <FormItem Field="@nameof(vItem.Name)" LabelText="Account Name">
                        <Template>
                            <SfTextBox @bind-Value="vItem.Name" Placeholder="Enter account name" />
                        </Template>
                    </FormItem>
                    <FormItem Field="@nameof(vItem.URL)" LabelText="URL">
                        <Template>
                            <SfTextBox @bind-Value="vItem.URL" Placeholder="https://" />
                        </Template>
                    </FormItem>
                    <FormItem Field="@nameof(vItem.Username)" LabelText="Username">
                        <Template>
                            <SfTextBox @bind-Value="vItem.Username" />
                        </Template>
                    </FormItem>
                    <FormItem Field="@nameof(vItem.Password)" LabelText="Password">
                        <Template>
                            <SfTextBox @bind-Value="vItem.Password" Type="InputType.Password" />
                        </Template>
                    </FormItem>
                </FormItems>
                <FormButtons>
                    <SfButton CssClass="e-outline me-2" OnClick="Cancel">Cancel</SfButton>
                    <SfButton IsPrimary="true" OnClick="SaveItem">Save</SfButton>
                </FormButtons>
            </SfDataForm>
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private bool _showDialog;
    private VaultItem _vaultItem;
    private RecordTypes.LoginDetail? vItem;
    private SfDialog _dialog;

    [Parameter] public EventCallback<RecordTypes.ItemUpdate> OnItemUpdated { get; set; }

    public async Task SetVaultItem(VaultItem item)
    {
        _vaultItem = item;
        if (_vaultItem != null)
            vItem = await VaultService.DecryptRecordTypeAsync<RecordTypes.LoginDetail>(_vaultItem);

        _showDialog = true;
        StateHasChanged();
    }

    private async Task SaveItem()
    {
        if (_vaultItem == null || vItem == null)
            return;

        string json = System.Text.Json.JsonSerializer.Serialize(vItem);
        var jsonBytes = System.Text.Encoding.UTF8.GetBytes(json);

        var (ciphertext, iv) = await VaultService.EncryptAsync(jsonBytes, VaultService.GetMasterKey());

        _vaultItem.EncryptedData = Convert.ToBase64String(ciphertext);
        _vaultItem.Iv = Convert.ToBase64String(iv);
        _vaultItem.Name = vItem.Name;

        await OnItemUpdated.InvokeAsync(new RecordTypes.ItemUpdate(_vaultItem, true));
        await HideAsync();
    }

    private async Task Cancel() => await HideAsync();

    public async Task ShowAsync()
    {
        _showDialog = true;
        await _dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        _showDialog = false;
        await _dialog.HideAsync();
    }
}
