@inject VaultService VaultService
@inject AccountService AccountService

<SfDialog Visible="false" AllowDragging="true" Width="450px"
          ShowCloseIcon="true" @ref="dialog">
    <DialogTemplates>
        <Content>
            <label class="text-lg font-bold mb-3">Add New Stored File</label>

            <SfDataForm @ref="dataForm" ID="AddFileItemForm"
                        Model="item" ColumnSpacing="20px">
                <FormValidator>
                    <DataAnnotationsValidator />
                </FormValidator>

                <FormItems>
                    <FormItem Field="@nameof(item.FileName)" LabelText="File Name" />
                    <FormItem Field="@nameof(item.Extension)" LabelText="File Extension" />
                </FormItems>

                <FormButtons>
                    <SfButton CssClass="e-outline" OnClick="Cancel">Cancel</SfButton>
                    <SfButton IsPrimary="true" Disabled="@IsProcessing" OnClick="SaveItem">Save Entry</SfButton>
                </FormButtons>
            </SfDataForm>

            <div class="mt-4">
                <SfUploader @ref="uploader"
                            MaxFileSize="262144000"
                            ShowProgressBar="true"
                            AutoUpload="false"
                            AllowMultiple="false">
                    <UploaderEvents ValueChange="HandleFileSelection" />
                </SfUploader>
            </div>

            @if (IsProcessing)
            {
                <div class="mt-4 text-center">
                    <SfSpinner Visible="true" Type="SpinnerType.Tailwind" />
                    <div class="mt-2">@Status</div>
                </div>
            }
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private SfDialog dialog;
    private SfDataForm dataForm;
    private SfUploader uploader;

    [Parameter] public EventCallback<VaultItem> ItemAdded { get; set; }

    private VaultItem NewItem { get; set; } = new();
    private RecordTypes.StoredFile item = new("", Array.Empty<byte>(), "");

    private bool IsProcessing { get; set; }
    private string Status { get; set; } = "";

    public async Task ShowAsync()
    {
        ResetForm();
        await dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        await dialog.HideAsync();
    }

    private void ResetForm()
    {
        NewItem = new VaultItem
        {
            CreatedAt = DateTime.UtcNow,
            Type = "File"
        };
        item = new RecordTypes.StoredFile("", Array.Empty<byte>(), "");
        Status = "";
        IsProcessing = false;
    }

    private async Task HandleFileSelection(UploadChangeEventArgs e)
    {
        var selected = e.Files.FirstOrDefault()?.File;
        if (selected is null) return;

        const long Limit = 250L * 1024 * 1024; //250MB

        if (selected.Size > Limit)
        {
            Status = "File size exceeds 250MB limit.";
            StateHasChanged();
            return;
        }

        IsProcessing = true;
        Status = "Reading and encrypting file…";
        StateHasChanged();

        try
        {
            await Task.Run(async () =>
            {
                using var ms = new MemoryStream();
                await selected.OpenReadStream(maxAllowedSize: Limit).CopyToAsync(ms);
                byte[] fileData = ms.ToArray();

                // Build StoredFile object and serialize
                item = new RecordTypes.StoredFile(selected.Name, fileData, Path.GetExtension(selected.Name));
                byte[] jsonBytes = JsonSerializer.SerializeToUtf8Bytes(item);

                // Encrypt
                var (ciphertext, iv) =
                    await VaultService.EncryptAsync(jsonBytes, VaultService.GetMasterKey());

                // Prepare
                NewItem = new VaultItem
                {
                    Name = selected.Name,
                    CreatedAt = DateTime.UtcNow,
                    UpdatedAt = DateTime.UtcNow,
                    Type = "File",
                    EncryptedData = Convert.ToBase64String(ciphertext),
                    Iv = Convert.ToBase64String(iv),
                    UserId = AccountService.LoginUser.Id
                };
            });

            Status = "File encrypted and ready to save.";
        }
        catch (Exception ex)
        {
            Status = "Error: " + ex.Message;
        }
        finally
        {
            IsProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SaveItem()
    {
        if (string.IsNullOrEmpty(NewItem.EncryptedData) || string.IsNullOrEmpty(NewItem.Iv))
        {
            Status = "No file data to save.";
            return;
        }

        await ItemAdded.InvokeAsync(NewItem);
        await HideAsync();
    }

    private async Task Cancel()
    {
        await HideAsync();
    }
}
