@using System.ComponentModel.DataAnnotations
@using ignivault.Data.Models.Data
@inject VaultService VaultService
@inject AccountService AccountService

<SfDialog @bind-Visible="_isOpen"
          @ref="_dialog"
          Width="90%" MaxWidth="650px"
          ShowCloseIcon="true"
          AllowDragging="true"
          IsModal="true"
          CssClass="custom-dialog"
          Header="Add New Note">

    <DialogTemplates>
        <Content>
            <EditForm Model="_noteItem" OnValidSubmit="SaveItemAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <!-- Title Input -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Note Title</label>
                    <SfTextBox @bind-Value="_noteItem.Title" Placeholder="Enter title" />
                </div>

                <!-- Rich Text Editor -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Content</label>
                    <SfRichTextEditor @bind-Value="_noteItem.Content"
                                      Height="300px"
                                      EnableResize="true"
                                      EnableTabKey="true"
                                      EnableXhtml="true"
                                      ShowCharCount="true"
                                      MaxLength="10000">
                        <RichTextEditorToolbarSettings Items="@Tools" />
                        <RichTextEditorQuickToolbarSettings Table="TableQuickToolbarItems"></RichTextEditorQuickToolbarSettings>
                        <RichTextEditorExportWord />
                        <RichTextEditorExportPdf />
                    </SfRichTextEditor>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex justify-content-end mt-3">
                    <SfButton CssClass="e-outline me-2" OnClick="Cancel" Disabled="_isSaving">Cancel</SfButton>
                    <SfButton IsPrimary="true" Type="Submit" Disabled="_isSaving">
                        @(_isSaving ? "Saving..." : "Save Entry")
                    </SfButton>
                </div>

                @if (!string.IsNullOrEmpty(_status))
                {
                    <div class="mt-2 text-danger small">@_status</div>
                }
            </EditForm>
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private SfDialog _dialog;
    private bool _isOpen;
    private bool _isSaving;
    private string _status = string.Empty;

    private VaultItem _newVaultItem;
    private NoteInputModel _noteItem = new();

    [Parameter] public EventCallback<VaultItem> ItemAdded { get; set; }

    public class NoteInputModel
    {
        [Required(ErrorMessage = "Title is required")]
        public string Title { get; set; } = string.Empty;

        public string Content { get; set; } = string.Empty;
    }

    private readonly List<ToolbarItemModel> Tools = new()
    {
        new ToolbarItemModel() { Command = ToolbarCommand.Bold },
        new ToolbarItemModel() { Command = ToolbarCommand.Italic },
        new ToolbarItemModel() { Command = ToolbarCommand.Underline },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.FontName },
        new ToolbarItemModel() { Command = ToolbarCommand.FontSize },
        new ToolbarItemModel() { Command = ToolbarCommand.FontColor },
        new ToolbarItemModel() { Command = ToolbarCommand.BackgroundColor },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.Alignments },
        new ToolbarItemModel() { Command = ToolbarCommand.NumberFormatList },
        new ToolbarItemModel() { Command = ToolbarCommand.BulletFormatList },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateLink },
        new ToolbarItemModel() { Command = ToolbarCommand.Image },
        new ToolbarItemModel() { Command = ToolbarCommand.Video },
        new ToolbarItemModel() { Command = ToolbarCommand.FullScreen },
        new ToolbarItemModel() { Command = ToolbarCommand.SourceCode },
    };

    private readonly List<TableToolbarItemModel> TableQuickToolbarItems = new()
    {
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableHeader },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableRows },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableColumns },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableCell },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableRemove },
        new TableToolbarItemModel() { Command = TableToolbarCommand.BackgroundColor }
    };

    public async Task ShowAsync()
    {
        ResetForm();
        _isOpen = true;
        await _dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        _isOpen = false;
        await _dialog.HideAsync();
    }

    private void ResetForm()
    {
        _noteItem = new NoteInputModel();
        _newVaultItem = new VaultItem { Type = "Text", CreatedAt = DateTime.UtcNow };
        _status = string.Empty;
        _isSaving = false;
    }

    private async Task SaveItemAsync()
    {
        try
        {
            _isSaving = true;
            _status = string.Empty;

            var storedNote = new RecordTypes.StoredNote(_noteItem.Title, _noteItem.Content);
            string jsonData = System.Text.Json.JsonSerializer.Serialize(storedNote);
            byte[] jsonBytes = System.Text.Encoding.UTF8.GetBytes(jsonData);
            var (ciphertext, iv) = await VaultService.EncryptAsync(jsonBytes, VaultService.GetMasterKey());

            _newVaultItem.EncryptedData = (ciphertext);
            _newVaultItem.Iv = (iv);
            _newVaultItem.Name = _noteItem.Title;
            _newVaultItem.UserId = AccountService.LoginUser.Id;
            _newVaultItem.CreatedAt = DateTime.UtcNow;
            _newVaultItem.UpdatedAt = DateTime.UtcNow;

            await ItemAdded.InvokeAsync(_newVaultItem);
            await HideAsync();
        }
        catch (Exception ex)
        {
            _status = $"Error saving note: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task Cancel() => await HideAsync();
}
