<SfDialog @bind-Visible="IsOpen"
          Width="500px"
          Header="@DialogHeader"
          IsModal="true"
          ShowCloseIcon="false">
    <DialogTemplates>
        <Content>
            <div class="p-4 space-y-4">

                @if (!IsResetMode)
                {
                    <!-- Original Key Mode -->
                    <p class="font-semibold mb-2">Enter your Vault Encryption Key to continue:</p>
                    <input class="form-control w-full"
                           @bind="EncryptionKey"
                           type="password"
                           placeholder="Current Vault Key" />

                    <div class="flex justify-end gap-2 mt-4">
                        <SfButton CssClass="e-primary" OnClick="Submit">Submit</SfButton>
                        <SfButton CssClass="e-flat" OnClick="Cancel">Cancel</SfButton>
                        <SfButton CssClass="e-danger" OnClick="EnableResetMode">Reset Vault Key</SfButton>
                    </div>
                }
                else
                {
                    <!-- Reset Mode -->
                    <p class="font-semibold mb-2">Reset your Vault Encryption Key</p>
                    <p class="text-sm text-gray-600">
                        Enter a new key below. Optionally supply your current encryption key for decryption.
                        <strong>If you do not supply it, all vault data will be permanently lost.</strong>
                    </p>

                    <SfTextBox @bind-Value="NewKey" OnInput="UpdateWarningState" Type="InputType.Password" Placeholder="New Vault Key (required)"></SfTextBox>
                    <SfTextBox @bind-Value="EncryptionKey" Oninput="UpdateWarningState" Type="InputType.Password" Placeholder="Current Vault Key (optional for decryption)"></SfTextBox>
                    
                    @if (ShowWarning)
                    {
                        <div class="bg-red-100 p-2 rounded border border-yellow-300 mt-2">
                            <SfMessage Severity="MessageSeverity.Warning">
                                Warning: No decryption key supplied. All vault data will be permanently lost!
                                <label>Type <strong>i understand</strong> to confirm:</label>
                            </SfMessage>
                            <SfTextBox @bind-Value="ConfirmText" Placeholder="i understand"></SfTextBox>
                        </div>
                    }

                    <div class="col-lg-12 control-section msg-default-section">
                        <div class="content-section">
                            <SfButton CssClass="e-primary" OnClick="SubmitReset" Disabled="@(!CanSubmitReset)">
                                Confirm Reset
                            </SfButton>
                            <SfButton CssClass="e-flat" OnClick="Cancel">Cancel</SfButton>
                       </div>
                    </div>
                }

            </div>
        </Content>
    </DialogTemplates>
</SfDialog>

<style>
    .msg-default-section .content-section {
        margin: 0 auto;
        max-width: 520px;
        padding-top: 10px;
    }

    .msg-default-section .e-message {
        margin: 10px 0;
    }
</style>

@code {
    private bool IsOpen { get; set; }
    private bool IsResetMode { get; set; } = false;

    private string EncryptionKey { get; set; } = string.Empty;
    private string NewKey { get; set; } = string.Empty;
    private string ConfirmText { get; set; } = string.Empty;
    private bool ShowWarning { get; set; } = false;

    private string DialogHeader => IsResetMode ? "Reset Vault Key" : "Vault Encryption Key";

    private TaskCompletionSource<(string NewKey, string? DecryptionKey, bool reset)?>? _tcs;

    private bool CanSubmitReset => 
        !string.IsNullOrWhiteSpace(NewKey) && 
        (!ShowWarning || ConfirmText?.ToLower() == "i understand");

    public Task<(string NewKey, string? DecryptionKey, bool reset)?> ShowAndWaitAsync()
    {
        ResetState();
        IsOpen = true;

        _tcs = new TaskCompletionSource<(string, string?, bool)?>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void EnableResetMode()
    {
        IsResetMode = true;
        ResetState();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(EncryptionKey))
            return;

        _tcs?.TrySetResult((NewKey: EncryptionKey, DecryptionKey: EncryptionKey, reset: false));
        Close();
    }

    private void SubmitReset()
    {
        if (string.IsNullOrWhiteSpace(NewKey))
            return;

        // If warning required and not yet confirmed, just update state
        if (ShowWarning && ConfirmText?.ToLower() != "i understand")
            return;

        _tcs?.TrySetResult((NewKey, string.IsNullOrWhiteSpace(EncryptionKey) ? null : EncryptionKey, reset: true));
        Close();
    }

    private void Cancel()
    {
        _tcs?.TrySetResult(null);
        Close();
    }

    private void Close()
    {
        IsOpen = false;
        IsResetMode = false;
        ResetState();
    }

    private void ResetState()
    {
        EncryptionKey = string.Empty;
        NewKey = string.Empty;
        ConfirmText = string.Empty;
        ShowWarning = false;
    }

    private void UpdateWarningState()
    {
        ShowWarning = IsResetMode && string.IsNullOrWhiteSpace(EncryptionKey);
    }
}
