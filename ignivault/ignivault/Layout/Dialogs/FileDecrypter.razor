@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject VaultService VaultService

<SfDialog @bind-Visible="IsOpen" Width="420px" Header="Decrypt File" IsModal="true">
    <DialogTemplates>
        <Content>
            <div class="p-3">
                <div class="mb-3">
                    <label class="form-label">Encrypted File</label>
                    <InputFile OnChange="OnFileSelected" />
                </div>

                <div class="mb-3">
                    <label class="form-label">File ID</label>
                    <input class="form-control" value="@StampedIdDisplay" readonly />
                </div>

                @if (!string.IsNullOrEmpty(Status))
                {
                    <div class="mb-2 text-muted">@Status</div>
                }

                <div class="d-flex justify-content-end gap-2">
                    <SfButton OnClick="DecryptAsync" CssClass="e-primary" Disabled="@(!CanDecrypt || _isDecrypting)">
                        @(_isDecrypting ? "Decrypting..." : "Decrypt")
                    </SfButton>
                    <SfButton OnClick="Close" Disabled="@_isDecrypting">Cancel</SfButton>
                </div>
            </div>
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private bool IsOpen { get; set; } = false;
    private VaultItem? VaultFile;
    private byte[]? EncryptedWithHeader;
    private long? StampedId;
    private string Status { get; set; } = "Idle";
    private bool _isDecrypting = false;

    public List<VaultItem> VaultItems { get; set; } = new();

    private string StampedIdDisplay => StampedId?.ToString() ?? "(none)";

    private bool CanDecrypt => VaultFile != null &&
                               EncryptedWithHeader != null &&
                               EncryptedWithHeader.Length > 0 &&
                               !string.IsNullOrWhiteSpace(VaultService.GetMasterKeyBase64());

    /// <summary>
    /// Open dialog with a list of VaultItems
    /// </summary>
    public void Open(List<VaultItem> items)
    {
        VaultItems = items;
        Reset();
        IsOpen = true;
        StateHasChanged();
    }

    private void Close()
    {
        IsOpen = false;
        Reset();
    }

    private void Reset()
    {
        VaultFile = null;
        EncryptedWithHeader = null;
        StampedId = null;
        Status = "Idle";
        _isDecrypting = false;
        StateHasChanged();
    }

    /// <summary>
    /// Read file from user and extract ID & encrypted data
    /// </summary>
    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            using var ms = new MemoryStream();
            await file.OpenReadStream(300 * 1024 * 1024).CopyToAsync(ms);

            ms.Position = 0;
            using var reader = new BinaryReader(ms);

            if (ms.Length >= 4)
            {
                StampedId = reader.ReadInt32();
                VaultFile = VaultItems.FirstOrDefault(v => v.Id == StampedId);

                if (VaultFile == null)
                {
                    Status = $"Warning: No matching file found with ID {StampedId}.";
                    EncryptedWithHeader = null;
                    return;
                }
            }

            EncryptedWithHeader = reader.ReadBytes((int)(ms.Length - 4));
            Status = $"Loaded {file.Name} ({EncryptedWithHeader?.Length} bytes)";
        }
        catch (Exception ex)
        {
            Status = $"Error reading file: {ex.Message}";
            EncryptedWithHeader = null;
            VaultFile = null;
        }

        StateHasChanged();
    }

    /// <summary>
    /// Decrypt file and save via browser
    /// </summary>
    private async Task DecryptAsync()
    {
        if (!CanDecrypt || VaultFile == null || EncryptedWithHeader == null) return;

        _isDecrypting = true;
        Status = "Decrypting...";
        StateHasChanged();

        try
        {
            VaultFile.EncryptedData = Convert.ToBase64String(EncryptedWithHeader);

            var decryptedFile = await VaultService.DecryptRecordTypeAsync<RecordTypes.StoredFile>(VaultFile);

         
            if (decryptedFile?.Data == null)
            {
                Status = "Decryption failed: No data retrieved.";
                return;
            }

            // Save file using JS helper
            await FileUtils.SaveAs(JS, VaultFile.Name, decryptedFile.Data);
            Status = "Decryption complete — download started.";
        }
        catch (Exception ex)
        {
            Status = $"Error during decryption: {ex.Message}";
        }
        finally
        {
            _isDecrypting = false;
            StateHasChanged();
        }
    }
}
