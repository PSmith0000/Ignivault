@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Nav
@inject AccountService AccountService
@inject VaultService VaultService

<head>
    <script src="js/Crypt.js"></script>
    <script src="js/downloadHelper.js"></script>
</head>

<div class="app-layout">
    <nav class="sidebar">
        <ul>
            @if (AccountService.LoginUser != null)
            {
                <li>
                    <NavLink href="dashboard">Vault</NavLink>
                </li>
                <li>
                    <NavLink href="account">Account</NavLink>
                </li>
                <li>
                    <button class="btn btn-link logout-btn" @onclick="Logout">Logout</button>
                </li>

                <AskKey @ref="keyDialog" />
            }
            else
            {
                <li>
                    <NavLink href="login">Login</NavLink>
                </li>
                <li>
                    <NavLink href="signup">Register</NavLink>
                </li>
            }
        </ul>
    </nav>

    <main>
        @Body
    </main>
</div>


<style>
    .app-layout {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 220px;
        background-color: #1b6ec2;
        padding: 1rem;
        color: white;
        flex-shrink: 0;
    }

        .sidebar ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .sidebar li {
            margin-bottom: 12px;
        }

        .sidebar a, .sidebar .btn-link {
            display: block;
            color: white;
            text-decoration: none;
            font-weight: 500;
            padding: 0.5rem 0;
            transition: background 0.2s, color 0.2s;
        }

            .sidebar a.active {
                font-weight: bold;
                border-left: 4px solid #fff;
                padding-left: 0.5rem;
            }

            .sidebar a:hover, .sidebar .btn-link:hover {
                color: #ffd700;
                text-decoration: none;
            }

    .logout-btn {
        padding: 0;
        font-size: 1rem;
        text-align: left;
        cursor: pointer;
        background: transparent;
        border: none;
    }

    main {
        flex: 1;
        background: #f8f9fa;
        padding: 1.5rem;
        min-height: 100vh;
    }

</style>

@code {
    private AskKey? keyDialog;
    private int FailedAttempts = 0;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private async Task<bool> PromptAndDecryptAsync(LoginUser user)
    {
        var key = await keyDialog!.ShowAndWaitAsync();
        if (!string.IsNullOrEmpty(key))
        {
            return await VaultService.DecryptMasterKeyAsync(user, key);
        }
        return false;
    }

    protected override async void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            if (!VaultService.IsMasterKeySet() && await AccountService.IsLoggedInAsync())
            {
                bool status = await PromptAndDecryptAsync(AccountService.LoginUser!);

                if (!status)
                {
                    await Logout();
                }
            }
        }
    }
}
