@using ignivault.Data.Models.Auth

<div class="col-lg-12 control-section" id="target">
    <div>
    </div>
    <SfDialog Target="#target" Width="500px" ShowCloseIcon="true" @bind-Visible="Visibility">
        <DialogTemplates>
            <Header> Ignivault: Password Reset </Header>
            <Content>
                <SfDataForm ID="forgot-form" Model="@account">
                    <FormValidator>
                        <DataAnnotationsValidator></DataAnnotationsValidator>
                    </FormValidator>
                    <FormItems>
                        <FormAutoGenerateItems></FormAutoGenerateItems>
                    </FormItems>
                </SfDataForm>
            </Content>
        </DialogTemplates>
        <DialogEvents OnOpen="@DialogOpen" Closed="@DialogClose"></DialogEvents>
        <DialogButtons>
            
        </DialogButtons>
    </SfDialog>
</div>
<style>
    a, a:hover, .highcontrast #dialog a, .highcontrast #dialog a:hover {
        color: inherit;
        text-decoration: none;
    }

    .fabric #target .e-dialog {
        height: 306px;
    }

    .material #target .e-dialog {
        height: 270px;
    }

    .bootstrap4 #target .e-dialog {
        height: 305px;
    }

    #target .e-dialog {
        height: 320px;
    }

    #target {
        height: 500px;
    }

    .e-dialog .e-dlg-header-content + .e-dlg-content {
        padding-bottom: 0;
    }
</style>
@code {
    private ForgotPasswordModel account = new ForgotPasswordModel();

    private bool Visibility { get; set; } = true;
    private bool ShowButton { get; set; } = false;
    private void DialogOpen(Object args)
    {
        this.ShowButton = false;
    }
    private void DialogClose(Object args)
    {
        this.ShowButton = true;
    }
}