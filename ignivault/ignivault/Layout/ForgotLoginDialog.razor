@using ignivault.Data.Models.Auth
@inject IHttpService HttpService

<div class="col-lg-12 control-section" id="target">
    <SfDialog Target="#target"
              Width="400px"
              ShowCloseIcon="true"
              @bind-Visible="Visibility"
              IsModal="true"
              Header="Ignivault: Password Reset">
        <DialogTemplates>
            <Content>
                <EditForm Model="account" OnValidSubmit="RequestResetAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <InputText @bind-Value="account.Email" class="form-control" placeholder="Enter your email" />
                        <ValidationMessage For="@(() => account.Email)" />
                    </div>

                    <div class="d-flex justify-content-end">
                        <SfButton IsPrimary="true" Type="Submit" Disabled="_isSubmitting">
                            @(_isSubmitting ? "Sending..." : "Send Reset Link")
                        </SfButton>
                    </div>

                    @if (!string.IsNullOrEmpty(_status))
                    {
                        <div class="mt-2 text-sm @( _success ? "text-success" : "text-danger")">
                            @_status
                        </div>
                    }
                </EditForm>
            </Content>
        </DialogTemplates>
    </SfDialog>
</div>

@code {
    private ForgotPasswordModel account = new ForgotPasswordModel();
    private bool Visibility { get; set; } = true;
    private bool _isSubmitting = false;
    private string? _status;
    private bool _success;

    private async Task RequestResetAsync()
    {
        if (string.IsNullOrWhiteSpace(account.Email))
        {
            _status = "Email is required.";
            _success = false;
            return;
        }

        try
        {
            _isSubmitting = true;
            var (success, message) = await HttpService.RequestPasswordResetAsync(account.Email);
            _status = message ?? (success ? "Reset link sent successfully!" : "Failed to send reset link.");
            _success = success;
        }
        catch (Exception ex)
        {
            _status = $"Error: {ex.Message}";
            _success = false;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
